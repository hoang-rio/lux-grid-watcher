ACCOUNT=your_account
PASSWORD=your_password
INVERT_SERIAL=your_inverter_SERIAL
DONGLE_SERIAL=your_dongle_SERIAL
CAST_DEVICE_NAME=your_chromecast_device_name
AUDIO_BASE_URL=http://you_audio_base_url
IS_DEBUG=True
BASE_URL=https://server.luxpowertek.com/WManage
SLEEP_TIME=120
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64; rv:124.0) Gecko/20100101 Firefox/124.0
LOG_FILE=logs/app.log
LOG_FORMAT=%(asctime)s %(filename)s:%(lineno)s [%(levelname)s]: %(message)s
STATE_FILE=grid_connect_state.ini
MAX_RETRY_COUNT=3
DONGLE_TCP_HOST=192.168.10.88
DONGLE_TCP_PORT=8000
WORKING_MODE=DONGLE
# Working mode options:
# DONGLE - Connect to dongle as client (default)
# SERVER - Listen for dongle connections on SERVER_MODE_PORT
# HTTP - Use HTTP API to get inverter data
# ReadInput mode options for DONGLE and SERVER mode:
# ALL - poll ReadInput1 -> ReadInput4 sequentially (registers 0,40,80,120)
# INPUT1 - only poll ReadInput1 (real-time data)
# INPUT2 - only poll ReadInput2 (energy totals/temps)
# INPUT3 - only poll ReadInput3 (battery BMS)
# INPUT4 - only poll ReadInput4 (generator/EPS)
# Comma-separated list supported (e.g. INPUT1,INPUT3)
READ_INPUT_MODE=INPUT1_ONLY

# Interval for reading low-frequency registers (40, 80, 120) when READ_INPUT_MODE=ALL.
# 1 = read every time (default), 10 = read every 10 times INPUT1 is read.
READ_LOW_FREQ_INTERVAL=10

# SERVER_MODE configuration (only used when WORKING_MODE=SERVER)
SERVER_MODE_HOST=0.0.0.0
SERVER_MODE_PORT=4346
SERVER_MODE_TIMEOUT=90  # default covers per-user max sleep_time (30s) => 30*3=90s
DEVICE_IDS_JSON_FILE=devices.json
FCM_PROJECT=fcm-project-id
FCM_ADMIN_KEY_FILE=fcm_admin_key.json
HISTORY_FILE=history.json
HISTORY_COUNT=10
LOG_FILE_SIZE=500
LOG_FILE_COUNT=3
RUN_WEB_VIEWER=True
PORT=88
HOST=0.0.0.0
# HTTPS support (optional)
# Set HTTPS_ENABLED=true to enable HTTPS listener on HTTPS_PORT.
HTTPS_ENABLED=false
# Optional separate port for HTTPS. If not set, it will default to PORT + 1.
HTTPS_PORT=8443
# Paths to the certificate and key (PEM format)
HTTPS_CERT_FILE=/path/to/fullchain.pem
HTTPS_KEY_FILE=/path/to/privkey.pem
# Optional password for encrypted private key
HTTPS_CERT_PASSWORD=

DB_NAME=db/web.db
ABNORMAL_DETECTION_ENABLED=true
ABNORMAL_CHECK_COOLDOWN_HOURS=3
MAX_INVERTERS_SYSTEM=10

# Multi-tenant PostgreSQL settings (new)
# Example: postgresql+psycopg://postgres:postgres@localhost:5432/lux_web_viewer
POSTGRES_DB_URL=

# JWT settings (new)
JWT_SECRET=please-change-me
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=30

# SMTP settings for email verification/password reset (new)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS=true
SMTP_SSL=false

# Optional IPv6 listener. If set, the web viewer will also bind an IPv6 address.
# Example: HOST_IPV6=::        (listen on all IPv6 addresses)
# Optional separate port for IPv6; defaults to PORT if not set.
HOST_IPV6=

# WebViewer authentication config
AUTH_ENABLED=true
AUTH_USERNAME=admin
AUTH_PASSWORD=changeme
AUTH_BYPASS_CIDR=127.0.0.1/32,::1/128
# Comma-separated list of CIDRs allowed to access admin features (settings + notification modification)
# If empty, no remote clients will be allowed to access admin features (only localhost if in list).
ADMIN_ALLOWED_CIDR=127.0.0.1/32,::1/128
