# Core runtime
TZ=Asia/Ho_Chi_Minh
IS_DEBUG=True
WORKING_MODE=SERVER
READ_INPUT_MODE=ALL
RUN_WEB_VIEWER=True
HOST=0.0.0.0
PORT=88
HTTPS_ENABLED=false
HTTPS_PORT=8443
SERVER_MODE_HOST=0.0.0.0
SERVER_MODE_PORT=4346
SERVER_MODE_TIMEOUT=300
SLEEP_TIME=120

# Legacy sqlite path kept only for compatibility with local files, not runtime chart storage in PG mode
DB_NAME=db/web.db
LOG_FILE=logs/app.log
LOG_FORMAT=%(asctime)s %(filename)s:%(lineno)s [%(levelname)s]: %(message)s
LOG_FILE_SIZE=500
LOG_FILE_COUNT=3
STATE_FILE=grid_connect_state.ini
HISTORY_FILE=history.json
HISTORY_COUNT=10
DEVICE_IDS_JSON_FILE=devices.json

# Inverter identity (used to map legacy migration and dongle mode)
INVERT_SERIAL=YOUR_INVERTER_SERIAL
DONGLE_SERIAL=YOUR_DONGLE_SERIAL

# Optional cloud API mode
ACCOUNT=
PASSWORD=
BASE_URL=https://server.luxpowertek.com/WManage
USER_AGENT=Mozilla/5.0

# PostgreSQL (dev)
POSTGRES_DB=lux_web_viewer
POSTGRES_USER=lux
POSTGRES_PASSWORD=lux_dev_password

# Multi-tenant auth
JWT_SECRET=dev-change-me
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=30
AUTH_ENABLED=false
AUTH_USERNAME=admin
AUTH_PASSWORD=changeme
AUTH_BYPASS_CIDR=127.0.0.1/32,::1/128
ADMIN_ALLOWED_CIDR=127.0.0.1/32,::1/128

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS=true
SMTP_SSL=false

# FCM
FCM_PROJECT=
FCM_ADMIN_KEY_FILE=fcm_admin_key.json
